# ============================================================
# 爆款短视频复刻SaaS平台 - 环境变量配置模板
# ============================================================
# 使用方法: cp .env.example .env && nano .env
# ============================================================

# ==================== 应用基础配置 ====================
# 应用名称
APP_NAME=爆款短视频复刻SaaS平台
# 应用版本
APP_VERSION=1.0.0
# 调试模式（生产环境必须设为 false）
DEBUG=false
# 允许的跨域域名（JSON数组格式）
CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]

# ==================== 数据库配置 ====================
# MySQL 异步连接URL（FastAPI使用）
# 格式: mysql+aiomysql://用户:密码@主机:端口/数据库?charset=utf8mb4
DATABASE_URL=mysql+aiomysql://sv_saas:SvSaas@2024Secure@mysql:3306/short_video_saas?charset=utf8mb4
# MySQL 同步连接URL（Alembic迁移使用）
DATABASE_SYNC_URL=mysql+pymysql://sv_saas:SvSaas@2024Secure@mysql:3306/short_video_saas?charset=utf8mb4
# MySQL root密码（Docker容器初始化使用）
MYSQL_ROOT_PASSWORD=Root@2024Secure
# MySQL数据库名
MYSQL_DATABASE=short_video_saas
# MySQL用户名
MYSQL_USER=sv_saas
# MySQL用户密码
MYSQL_PASSWORD=SvSaas@2024Secure
# MySQL端口（宿主机映射）
MYSQL_PORT=3306

# ==================== Redis 配置 ====================
# Redis 连接URL（主库，用于缓存和限流）
REDIS_URL=redis://:@redis:6379/0
# Redis Broker（Celery消息队列）
CELERY_BROKER_URL=redis://:@redis:6379/1
# Redis Backend（Celery任务结果存储）
CELERY_RESULT_BACKEND=redis://:@redis:6379/2
# Redis密码（生产环境务必设置）
REDIS_PASSWORD=
# Redis端口（宿主机映射）
REDIS_PORT=6379

# ==================== JWT 认证 ====================
# JWT密钥（生产环境必须替换为随机字符串，至少32位）
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
# JWT算法
ALGORITHM=HS256
# 访问令牌有效期（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# 刷新令牌有效期（天）
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== 接口限流 ====================
# 每分钟最大请求数（单个IP/用户）
RATE_LIMIT_PER_MINUTE=60
# 每日最大请求数（单个IP/用户）
RATE_LIMIT_PER_DAY=10000

# ==================== 免费用户每日额度 ====================
# 免费用户每日解析次数
FREE_DAILY_PARSE_LIMIT=3
# 免费用户每日生成次数
FREE_DAILY_GENERATE_LIMIT=1
# 基础会员每日解析次数
BASIC_DAILY_PARSE_LIMIT=10
# 基础会员每日生成次数
BASIC_DAILY_GENERATE_LIMIT=5
# 高级会员每日解析次数
PREMIUM_DAILY_PARSE_LIMIT=50
# 高级会员每日生成次数
PREMIUM_DAILY_GENERATE_LIMIT=20

# ==================== 视频处理 ====================
# FFmpeg二进制路径（Docker内通常为 ffmpeg）
FFmpeg_BINARIES=ffmpeg
# 临时文件目录
TEMP_DIR=./temp
# 视频存储目录
VIDEO_STORAGE_PATH=./videos
# 最大上传文件大小（MB）
MAX_VIDEO_SIZE_MB=500

# ==================== 微信支付V3 ====================
# 微信AppID（微信公众平台）
WECHAT_APPID=
# 微信AppSecret
WECHAT_SECRET=
# 微信支付商户号
WECHAT_MCH_ID=
# 微信支付APIv3密钥（32位字符）
WECHAT_API_KEY=
# 微信支付回调地址（生产环境填公网URL）
WECHAT_NOTIFY_URL=https://yourdomain.com/api/payments/wechat/notify
# 微信支付证书路径（apiclient_key.pem）
WECHAT_CERT_PATH=./cert/apiclient_key.pem

# ==================== 支付宝 ====================
# 支付宝应用ID
ALIPAY_APP_ID=
# 支付宝应用私钥（RSA2格式）
ALIPAY_PRIVATE_KEY=
# 支付宝公钥
ALIPAY_PUBLIC_KEY=
# 支付宝回调地址
ALIPAY_NOTIFY_URL=https://yourdomain.com/api/payments/alipay/notify
# 支付宝网关地址
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# ==================== 阿里云短信 ====================
# 阿里云AccessKey ID
ALIBABA_CLOUD_ACCESS_KEY_ID=
# 阿里云AccessKey Secret
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
# 短信模板ID
ALIBABA_CLOUD_SMS_TEMPLATE_ID=
# 短信签名
ALIBABA_CLOUD_SIGN_NAME=

# ==================== AI 服务 - 即梦(Jimeng) ====================
# 即梦API密钥（申请地址: https://jimeng.jianying.com/）
JIMENG_API_KEY=
# 即梦API基础URL
JIMENG_BASE_URL=https://api.jimeng.jianying.com/visual/api

# ==================== AI 服务 - 百度可灵(Kling) ====================
# 可灵API密钥（申请地址: https://klingai.com/）
KLING_API_KEY=
# 可灵API基础URL
KLING_BASE_URL=https://klingai.com/api

# ==================== AI 服务 - Whisper ====================
# Whisper模型大小: tiny/base/small/medium/large
WHISPER_MODEL=base
# 设备: cuda/cpu
WHISPER_DEVICE=cuda

# ==================== TTS 语音合成 ====================
# 阿里云TTS API密钥（DashScope）
ALIYUN_TTS_API_KEY=
# 腾讯云TTS密钥
TENCENT_TTS_SECRET_ID=
TENCENT_TTS_SECRET_KEY=

# ==================== 大模型 API（文案改写） ====================
# 兼容OpenAI格式的API Base URL
OPENAI_API_BASE=https://apihub.agnes-ai.com/v1
# API Key
OPENAI_API_KEY=
# 使用的模型
OPENAI_MODEL=agnes-2.0-flash

# ==================== Celery Worker ====================
# Worker并发数
CELERY_WORKERS=4
# Worker副本数（横向扩容）
CELERY_REPLICAS=1

# ==================== 后端服务 ====================
# 后端端口（宿主机映射）
BACKEND_PORT=8000

# ==================== 日志配置 ====================
# 日志级别: DEBUG/INFO/WARNING/ERROR
LOG_LEVEL=INFO
# 日志保留天数
LOG_RETENTION_DAYS=30