# 爆款短视频复刻SaaS平台 - 环境变量配置模板
# 复制为 .env 文件并填入实际值

# ==================== 基础配置 ====================
APP_NAME=爆款短视频复刻SaaS平台
DEBUG=false
CORS_ORIGINS=[\"http://localhost:5173\",\"http://localhost:3000\"]

# ==================== 数据库 ====================
DATABASE_URL=mysql+aiomysql://root:your_password@localhost:3306/short_video_saas
DATABASE_SYNC_URL=mysql+pymysql://root:your_password@localhost:3306/short_video_saas

# ==================== Redis ====================
REDIS_URL=redis://localhost:6379/0

# ==================== Celery ====================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ==================== JWT ====================
SECRET_KEY=change-this-to-a-random-32-char-minimum-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== 限流配置 ====================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_DAY=10000

# ==================== 短信服务 ====================
ALIBABA_CLOUD_ACCESS_KEY_ID=your_access_key_id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_access_key_secret
ALIBABA_CLOUD_SMS_TEMPLATE_ID=your_template_id
ALIBABA_CLOUD_SIGN_NAME=your_sign_name

# ==================== 每日次数配置 ====================
FREE_DAILY_PARSE_LIMIT=3
FREE_DAILY_GENERATE_LIMIT=1
BASIC_DAILY_PARSE_LIMIT=10
BASIC_DAILY_GENERATE_LIMIT=5
PREMIUM_DAILY_PARSE_LIMIT=50
PREMIUM_DAILY_GENERATE_LIMIT=20

# ==================== 微信支付 ====================
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret
WECHAT_MCH_ID=your_merchant_id
WECHAT_API_KEY=your_api_v3_key
WECHAT_NOTIFY_URL=https://your-domain.com/api/payments/wechat/notify

# ==================== 支付宝 ====================
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_app_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key
ALIPAY_NOTIFY_URL=https://your-domain.com/api/payments/alipay/notify

# ==================== 视频处理 ====================
FFMPEG_BINARIES=ffmpeg
TEMP_DIR=./temp
VIDEO_STORAGE_PATH=./videos

# ==================== AI 服务 ====================
JIMENG_API_KEY=your_jimeng_api_key
KLING_API_KEY=your_kling_api_key
WHISPER_MODEL=base
WHISPER_DEVICE=cuda
